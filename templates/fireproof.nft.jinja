#!/usr/sbin/nft -f
# {{ profile.description }}
# Profile: {{ profile.name }}
# Generated by awesome-nftable-conf — do not edit by hand

table inet filter {
  define WAN_IF = "{{ interfaces.wan }}"
{% if features.vpn | default(true) %}
  define VPN_IF = "{{ interfaces.vpn }}"
{% endif %}
{% if features.tailscale | default(true) %}
  define TAIL_IF = "{{ interfaces.tailscale }}"
{% endif %}

  #
  # INPUT
  #
  chain input {
    type filter hook input priority 0;
    policy {{ "drop" if features.input_drop | default(true) else "accept" }};

    iif lo accept
    ct state established,related accept

{% if features.lan_input | default(true) %}
{% for cidr in network.lan_cidrs %}
    ip saddr {{ cidr }} accept
{% endfor %}
{% endif %}
{% if features.tailscale | default(true) %}
    iifname $TAIL_IF accept
{% endif %}
{% if features.icmp | default(true) %}
    ip protocol icmp accept
{% endif %}
{% for rule in input_extra | default([]) %}
    {{ rule }}
{% endfor %}
  }

  #
  # FORWARD
  #
  chain forward {
    type filter hook forward priority 0;
    policy accept;

{% if features.docker_forward | default(true) and bridge_interfaces %}
    iifname { {% for iface in bridge_interfaces %}"{{ iface }}"{% if not loop.last %}, {% endif %}{% endfor %} } accept
    oifname { {% for iface in bridge_interfaces %}"{{ iface }}"{% if not loop.last %}, {% endif %}{% endfor %} } accept
{% endif %}
{% for rule in forward_extra | default([]) %}
    {{ rule }}
{% endfor %}
  }

  #
  # OUTPUT (kill-switch core)
  #
  chain output {
    type filter hook output priority 0;
    policy {{ "drop" if features.killswitch | default(true) else "accept" }};

    oif lo accept
    ct state established,related accept

{% if features.block_ipv6 | default(false) %}
    meta l4proto ipv6 drop
{% endif %}
{% if features.proton_wan_bootstrap | default(true) %}
    # WAN bootstrap — VPN must dial out before tunnel is up (ProtonVPN, Mullvad, etc.)
    oifname $WAN_IF ct state new,established accept
{% endif %}
{% if features.vpn | default(true) %}
    oifname $VPN_IF accept
{% endif %}
{% if features.tailscale | default(true) %}
    oifname $TAIL_IF accept
{% endif %}
{% if features.lan_output | default(true) %}
{% for cidr in network.lan_cidrs %}
    ip daddr {{ cidr }} accept
{% endfor %}
{% endif %}
{% if features.tor_proxy | default(true) %}
    meta mark { {{ marks.proxy }}, {{ marks.tor }} } accept
{% endif %}
{% for rule in output_extra | default([]) %}
    {{ rule }}
{% endfor %}
  }

{% if features.tor_proxy | default(true) %}
  #
  # MARKING LAYER (proxy chain — no DNS interference)
  #
  chain proxy_mark {
    type filter hook output priority mangle;
    policy accept;

{% for port in redirect_ports %}
    tcp dport {{ port }}{% if port in (proxy.mark_new_only_ports | default([443])) %} ct state new{% endif %} meta mark set {{ marks.proxy }}
{% endfor %}
    tcp dport {{ tor.socks_port }} meta mark set {{ marks.tor }}
  }
{% endif %}
}

{% if features.tor_proxy | default(true) %}
table ip nat {

  #
  # LAN / forwarded proxy redirection → Tor
  #
  chain prerouting {
    type nat hook prerouting priority -100;
    policy accept;

    meta mark {{ marks.proxy }} tcp dport { {% for port in redirect_ports %}{{ port }}{% if not loop.last %}, {% endif %}{% endfor %} } redirect to :{{ tor.socks_port }}
{% for rule in nat_prerouting_extra | default([]) %}
    {{ rule }}
{% endfor %}
  }

  #
  # LOCAL machine proxy redirect → Tor
  #
  chain output {
    type nat hook output priority -100;
    policy accept;

    meta mark {{ marks.proxy }} tcp dport { {% for port in redirect_ports %}{{ port }}{% if not loop.last %}, {% endif %}{% endfor %} } redirect to :{{ tor.socks_port }}
{% for rule in nat_output_extra | default([]) %}
    {{ rule }}
{% endfor %}
  }
}
{% endif %}
